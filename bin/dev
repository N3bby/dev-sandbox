#!/usr/bin/env zsh
set -e

REPO_DIR="${0:A:h}/.."
CONTAINER_NAME="dev-$(basename "$(pwd)")"
IMAGE_NAME="capytalli-image"
WORKDIR="$(pwd)"
MOUNTS_FILE="$REPO_DIR/mounts"

# --- Self-update ---
git -C "$REPO_DIR" pull --quiet

# --- Build image ---
echo "Building Docker image..."
docker build -t "$IMAGE_NAME" "$REPO_DIR"

# --- Resolve optional mounts from config ---
MOUNTS=()
if [ -f "$MOUNTS_FILE" ]; then
  while IFS= read -r line; do
    [[ -z "$line" || "$line" == \#* ]] && continue
    line="${line/#\~/$HOME}"
    src="${line%%:*}"
    rest="${line#*:}"
    tgt="${rest%%:*}"
    opt="${rest#*:}"
    extra=""
    [[ "$opt" == "ro" ]] && extra=",readonly"
    if [ -e "$src" ]; then
      MOUNTS+=("--mount" "source=${src},target=${tgt},type=bind${extra}")
    else
      echo "Warning: skipping mount ${src} (not found)" >&2
    fi
  done < "$MOUNTS_FILE"
else
  echo "Warning: no mounts config found at $MOUNTS_FILE — running without optional mounts" >&2
fi

# --- Run container ---
echo "Starting container '$CONTAINER_NAME'..."
docker run -it --rm \
  --name "$CONTAINER_NAME" \
  --env "HOST_UID=$(id -u)" \
  --env "HOST_GID=$(id -g)" \
  --volume "$(pwd):$WORKDIR" \
  --workdir "$WORKDIR" \
  "${MOUNTS[@]}" \
  "$IMAGE_NAME" \
  "$@"
