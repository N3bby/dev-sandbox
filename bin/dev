#!/bin/bash
set -e

BOLD=$'\033[1m'
GREEN=$'\033[0;32m'
CYAN=$'\033[0;36m'
YELLOW=$'\033[0;33m'
RESET=$'\033[0m'

# Resolve symlinks portably (readlink -f is GNU-only, not available on macOS)
_script="$0"
while [ -L "$_script" ]; do
  _dir="$(cd "$(dirname "$_script")" && pwd)"
  _script="$(readlink "$_script")"
  case "$_script" in /*) ;; *) _script="$_dir/$_script" ;; esac
done
REPO_DIR="$(cd "$(dirname "$_script")" && pwd)/.."
unset _script _dir
CONTAINER_NAME="dev-$(basename "$(pwd)" | tr ' ' '_')"
IMAGE_NAME="capytalli-image"
WORKDIR="/home/ubuntu/project/$(basename "$(pwd)")"
MOUNTS_FILE="$REPO_DIR/mounts"

echo ""
echo "${BOLD}🐳 dev-sandbox${RESET}"
echo ""

# --- Self-update ---
echo "  🔄 Checking for updates..."
_old_rev=$(git -C "$REPO_DIR" rev-parse HEAD)
git -C "$REPO_DIR" pull --quiet
if [ "$(git -C "$REPO_DIR" rev-parse HEAD)" != "$_old_rev" ]; then
  echo "     ${GREEN}✅ Updated — restarting...${RESET}"
  echo ""
  exec "$0" "$@"
fi
echo "     ${GREEN}✅ Up to date${RESET}"
echo ""
unset _old_rev

# --- Build image ---
echo "  🔨 Building Docker image..."
docker build -t "$IMAGE_NAME" "$REPO_DIR"
echo "     ${GREEN}✅ Image ready${RESET}"
echo ""

# --- Resolve optional mounts from config ---
MOUNTS=()
if [ -f "$MOUNTS_FILE" ]; then
  while IFS= read -r line; do
    [[ -z "$line" || "$line" == \#* ]] && continue
    line="${line/#\~/$HOME}"
    IFS=: read -r src tgt opt <<< "$line"
    extra=""
    [[ "$opt" == "ro" ]] && extra=",readonly"
    if [ -e "$src" ]; then
      MOUNTS+=("--mount" "source=${src},target=${tgt},type=bind${extra}")
    else
      echo "     ${YELLOW}⚠️  Skipping mount ${CYAN}${src}${YELLOW} (not found)${RESET}" >&2
    fi
  done < "$MOUNTS_FILE"
else
  echo "  ${YELLOW}⚠️  No mounts config found at ${CYAN}${MOUNTS_FILE}${YELLOW} — running without optional mounts${RESET}" >&2
fi

# --- Run container ---
echo "  🚀 Starting container ${CYAN}${CONTAINER_NAME}${RESET}..."
echo ""
clear
docker run -it --rm \
  --name "$CONTAINER_NAME" \
  --security-opt label=disable \
  --env "HOST_UID=$(id -u)" \
  --env "HOST_GID=$(id -g)" \
  --volume "$(pwd):$WORKDIR" \
  --workdir "$WORKDIR" \
  "${MOUNTS[@]}" \
  "$IMAGE_NAME" \
  "$@"
