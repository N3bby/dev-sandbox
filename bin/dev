#!/bin/bash
set -e

GREEN=$'\033[0;32m'
CYAN=$'\033[0;36m'
YELLOW=$'\033[0;33m'
RESET=$'\033[0m'

# Resolve symlinks portably (readlink -f is GNU-only, not available on macOS)
_script="$0"
while [ -L "$_script" ]; do
  _dir="$(cd "$(dirname "$_script")" && pwd)"
  _script="$(readlink "$_script")"
  case "$_script" in /*) ;; *) _script="$_dir/$_script" ;; esac
done
REPO_DIR="$(cd "$(dirname "$_script")" && pwd)/.."
unset _script _dir
CWD="$(pwd)"
PROJECT_NAME="$(basename "$CWD")"
# Random suffix so sandboxes in identically named dirs don't collide on --name
CONTAINER_NAME="dev-${PROJECT_NAME// /_}-$(printf '%04x' "$RANDOM")"
IMAGE_NAME="dev-sandbox"
WORKDIR="/workspace/$PROJECT_NAME"
MOUNTS_FILE="$REPO_DIR/mounts"

# --- Attach mode: skip update/build, exec a new shell into a running container ---
if [[ "${1:-}" == "--attach" || "${1:-}" == "-a" ]]; then
  shift

  # Identify running dev containers for THIS directory by the CWD->WORKDIR bind
  # mount. Name alone is ambiguous: the same basename in a different path
  # produces the same dev-<name>-* prefix. The name filter is only a prefilter.
  matches=()
  while IFS= read -r name; do
    [ -z "$name" ] && continue
    if docker inspect -f '{{range .Mounts}}{{.Source}}={{.Destination}}{{println}}{{end}}' "$name" 2>/dev/null \
         | grep -qxF "$CWD=$WORKDIR"; then
      matches+=("$name")
    fi
  done < <(docker ps --filter "name=dev-${PROJECT_NAME// /_}-" --format '{{.Names}}')

  if [ "${#matches[@]}" -eq 0 ]; then
    echo "${YELLOW}No running dev container found for ${CWD}.${RESET}" >&2
    echo "Start one with: ${CYAN}dev${RESET}" >&2
    exit 1
  fi

  target="${matches[0]}"                 # docker ps lists newest first
  if [ "${#matches[@]}" -gt 1 ]; then
    echo "Multiple dev containers are running for this directory:"
    for i in "${!matches[@]}"; do
      printf "  %d) %s\n" "$((i + 1))" "${matches[$i]}"
    done
    printf "Attach to which? [1-%d] (default 1, newest): " "${#matches[@]}"
    read -r choice
    [ -z "$choice" ] && choice=1
    if ! [[ "$choice" =~ ^[0-9]+$ ]] || [ "$choice" -lt 1 ] || [ "$choice" -gt "${#matches[@]}" ]; then
      echo "${YELLOW}Invalid selection.${RESET}" >&2
      exit 1
    fi
    target="${matches[$((choice - 1))]}"
  fi

  [ "$#" -eq 0 ] && set -- /usr/bin/zsh    # default to a shell; allow `dev --attach <cmd>`
  echo "Attaching to ${CYAN}${target}${RESET}..."
  exec docker exec -it -w "$WORKDIR" "$target" gosu "$(id -u)" "$@"
fi

# --- Self-update (best-effort; never block on an offline or failed pull) ---
echo "Checking for updates..."
_old_rev=$(git -C "$REPO_DIR" rev-parse HEAD)
if GIT_TERMINAL_PROMPT=0 git -C "$REPO_DIR" pull --quiet; then
  if [ "$(git -C "$REPO_DIR" rev-parse HEAD)" != "$_old_rev" ]; then
    echo "${GREEN}Updated â€” restarting...${RESET}"
    exec "$0" "$@"
  fi
else
  echo "${YELLOW}Update check failed â€” continuing with current version.${RESET}" >&2
fi
unset _old_rev

# --- Build image ---
echo "Building Docker image..."
docker build -t "$IMAGE_NAME" "$REPO_DIR"

# --- Resolve optional mounts from config ---
MOUNTS=()
if [ -f "$MOUNTS_FILE" ]; then
  while IFS= read -r line; do
    [[ -z "$line" || "$line" == \#* ]] && continue
    line="${line/#\~/$HOME}"
    IFS=: read -r src tgt opt <<< "$line"
    extra=""
    [[ "$opt" == "ro" ]] && extra=",readonly"
    if [ -e "$src" ]; then
      MOUNTS+=("--mount" "source=${src},target=${tgt},type=bind${extra}")
    else
      echo "${YELLOW}Warning: skipping mount ${src} (not found)${RESET}" >&2
    fi
  done < "$MOUNTS_FILE"
else
  echo "${YELLOW}Warning: no mounts config found at ${MOUNTS_FILE} â€” running without optional mounts${RESET}" >&2
fi

# --- Run container ---
echo "Starting ${CYAN}${CONTAINER_NAME}${RESET}..."
clear
docker run -it --rm \
  --name "$CONTAINER_NAME" \
  --security-opt label=disable \
  --env "HOST_UID=$(id -u)" \
  --env "HOST_GID=$(id -g)" \
  --volume "$CWD:$WORKDIR" \
  --workdir "$WORKDIR" \
  "${MOUNTS[@]}" \
  "$IMAGE_NAME" \
  "$@"
