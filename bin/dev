#!/bin/bash
set -e

GREEN=$'\033[0;32m'
CYAN=$'\033[0;36m'
YELLOW=$'\033[0;33m'
RESET=$'\033[0m'

IMAGE_NAME="dev-sandbox"

# Resolve this script's real location (following symlinks) and derive every
# path/name the rest of the script relies on. Sets the globals REPO_DIR, CWD,
# PROJECT_NAME, WORKDIR, MOUNTS_FILE and CONTAINER_PREFIX.
init_environment() {
  # Resolve symlinks portably (readlink -f is GNU-only, not available on macOS)
  local script="$0" dir
  while [ -L "$script" ]; do
    dir="$(cd "$(dirname "$script")" && pwd)"
    script="$(readlink "$script")"
    case "$script" in /*) ;; *) script="$dir/$script" ;; esac
  done

  REPO_DIR="$(cd "$(dirname "$script")" && pwd)/.."
  CWD="$(pwd)"
  PROJECT_NAME="$(basename "$CWD")"
  WORKDIR="/workspace/$PROJECT_NAME"
  MOUNTS_FILE="$REPO_DIR/mounts"
  # Name prefix shared by every container for this project. The random suffix
  # (added at run time) keeps sandboxes in identically named dirs from colliding.
  CONTAINER_PREFIX="dev-${PROJECT_NAME// /_}-"
}

# Attach mode: skip update/build and exec a new shell into a container already
# running for this directory. Any args are run as a command instead of a shell
# (e.g. `dev --attach ls`). Execs on success, so this never returns.
attach_to_container() {
  # Identify running dev containers for THIS directory by the CWD->WORKDIR bind
  # mount. Name alone is ambiguous: the same basename in a different path
  # produces the same dev-<name>-* prefix. The name filter is only a prefilter.
  local matches=() name
  while IFS= read -r name; do
    [ -z "$name" ] && continue
    if docker inspect -f '{{range .Mounts}}{{.Source}}={{.Destination}}{{println}}{{end}}' "$name" 2>/dev/null \
         | grep -qxF "$CWD=$WORKDIR"; then
      matches+=("$name")
    fi
  done < <(docker ps --filter "name=$CONTAINER_PREFIX" --format '{{.Names}}')

  if [ "${#matches[@]}" -eq 0 ]; then
    echo "${YELLOW}No running dev container found for ${CWD}.${RESET}" >&2
    echo "Start one with: ${CYAN}dev${RESET}" >&2
    exit 1
  fi

  local target="${matches[0]}"             # docker ps lists newest first
  [ "${#matches[@]}" -gt 1 ] && target="$(choose_container "${matches[@]}")"

  [ "$#" -eq 0 ] && set -- /usr/bin/zsh    # default to a shell
  echo "Attaching to ${CYAN}${target}${RESET}..."
  exec docker exec -it -w "$WORKDIR" "$target" gosu "$(id -u)" "$@"
}

# Prompt the user to pick one of several matching containers and echo the
# choice. Prompts go to stderr so only the chosen name lands on stdout.
choose_container() {
  local matches=("$@") choice i
  {
    echo "Multiple dev containers are running for this directory:"
    for i in "${!matches[@]}"; do
      printf "  %d) %s\n" "$((i + 1))" "${matches[$i]}"
    done
    printf "Attach to which? [1-%d] (default 1, newest): " "${#matches[@]}"
  } >&2
  read -r choice
  [ -z "$choice" ] && choice=1
  if ! [[ "$choice" =~ ^[0-9]+$ ]] || [ "$choice" -lt 1 ] || [ "$choice" -gt "${#matches[@]}" ]; then
    echo "${YELLOW}Invalid selection.${RESET}" >&2
    exit 1
  fi
  echo "${matches[$((choice - 1))]}"
}

# Pull the latest version of this repo and restart if it changed. Best-effort:
# an offline or failed pull never blocks the run.
self_update() {
  echo "Checking for updates..."
  local old_rev
  old_rev=$(git -C "$REPO_DIR" rev-parse HEAD)
  if GIT_TERMINAL_PROMPT=0 git -C "$REPO_DIR" pull --quiet; then
    if [ "$(git -C "$REPO_DIR" rev-parse HEAD)" != "$old_rev" ]; then
      echo "${GREEN}Updated — restarting...${RESET}"
      exec "$0" "$@"
    fi
  else
    echo "${YELLOW}Update check failed — continuing with current version.${RESET}" >&2
  fi
}

build_image() {
  echo "Building Docker image..."
  # --network=host uses the host's DNS instead of Docker's bridge resolver, which
  # refuses lookups on some machines (VPNs, split-DNS, systemd-resolved).
  #
  # --build-arg HOST_UID/HOST_GID bakes ownership of /home/ubuntu into the image
  # (the Dockerfile renumbers the `ubuntu` user to match and installs as it), so
  # there's no runtime chown. The image is built locally per host, and `id -u` is
  # stable, so layer caching holds across runs — only the first build pays for it.
  docker build --network=host \
    --build-arg HOST_UID="$(id -u)" \
    --build-arg HOST_GID="$(id -g)" \
    -t "$IMAGE_NAME" "$REPO_DIR"
}

# Read the optional mounts config into the MOUNTS array as `docker run` flags,
# skipping comments, blank lines and any source path that doesn't exist.
resolve_mounts() {
  MOUNTS=()
  if [ ! -f "$MOUNTS_FILE" ]; then
    echo "${YELLOW}Warning: no mounts config found at ${MOUNTS_FILE} — running without optional mounts${RESET}" >&2
    return
  fi

  local line src tgt opt extra
  while IFS= read -r line; do
    [[ -z "$line" || "$line" == \#* ]] && continue
    line="${line/#\~/$HOME}"
    IFS=: read -r src tgt opt <<< "$line"
    extra=""
    [[ ",$opt," == *,ro,* ]] && extra=",readonly"
    # `mkdir`/`touch`/`json` opts: create a missing source on the host first, so
    # tool config/data can persist without pre-existing there. `mkdir` makes a
    # directory, `touch` an empty file, and `json` a file seeded with `{}`. The
    # `json` case also re-seeds a source that exists but is empty: an empty file
    # is invalid JSON, which makes tools like Claude Code fail to start.
    if [[ ",$opt," == *,mkdir,* ]] && [ ! -e "$src" ]; then
      if mkdir -p "$src"; then
        echo "${GREEN}Created ${src}${RESET}" >&2
      else
        echo "${YELLOW}Warning: could not create ${src}${RESET}" >&2
      fi
    elif [[ ",$opt," == *,touch,* ]] && [ ! -e "$src" ]; then
      if mkdir -p "$(dirname "$src")" && touch "$src"; then
        echo "${GREEN}Created ${src}${RESET}" >&2
      else
        echo "${YELLOW}Warning: could not create ${src}${RESET}" >&2
      fi
    elif [[ ",$opt," == *,json,* ]] && [ ! -s "$src" ]; then
      if mkdir -p "$(dirname "$src")" && printf '{}\n' > "$src"; then
        echo "${GREEN}Seeded ${src} with {}${RESET}" >&2
      else
        echo "${YELLOW}Warning: could not create ${src}${RESET}" >&2
      fi
    fi
    if [ -e "$src" ]; then
      MOUNTS+=("--mount" "source=${src},target=${tgt},type=bind${extra}")
    else
      echo "${YELLOW}Warning: skipping mount ${src} (not found)${RESET}" >&2
    fi
  done < "$MOUNTS_FILE"
}

# Start the container with the CWD mounted at WORKDIR, running as the host user.
run_container() {
  local container_name="${CONTAINER_PREFIX}$(printf '%04x' "$RANDOM")"
  echo "Starting ${CYAN}${container_name}${RESET}..."
  clear
  docker run -it --rm \
    --name "$container_name" \
    --security-opt label=disable \
    --env "HOST_UID=$(id -u)" \
    --env "HOST_GID=$(id -g)" \
    --env "IS_SANDBOX=1" \
    --volume "$CWD:$WORKDIR" \
    --workdir "$WORKDIR" \
    "${MOUNTS[@]}" \
    "$IMAGE_NAME" \
    "$@"
}

# Every dev container is a throwaway sandbox, so `dev claude` skips Claude Code's
# permission prompts: inject --dangerously-skip-permissions when the command is
# `claude`, pass anything else (including a bare shell) through untouched. Paired
# with IS_SANDBOX=1 so the flag is honoured even when HOST_UID=0 (claude as root).
enable_claude_bypass() {
  CMD=("$@")
  if [[ "${CMD[0]:-}" == "claude" ]]; then
    CMD=(claude --dangerously-skip-permissions "${CMD[@]:1}")
  fi
}

main() {
  init_environment

  if [[ "${1:-}" == "--attach" || "${1:-}" == "-a" ]]; then
    shift
    attach_to_container "${CMD[@]}"   # execs into the running container; never returns
  fi

  self_update "$@"             # may re-exec this script; pass the user's original args
  build_image
  resolve_mounts
  enable_claude_bypass "$@"
  run_container "${CMD[@]}"
}

main "$@"
